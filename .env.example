# Vikunja MCP Server Configuration

# Vikunja API URL (required)
# IMPORTANT: Must include the full API path /api/v1
VIKUNJA_URL=https://vikunja.example.com/api/v1

# Vikunja API token (required)
# Generate in Vikunja: Settings > API Tokens
# Click "Create a new token", copy the token value
VIKUNJA_API_TOKEN=your-api-token-here

# Optional: SSL verification (default: true)
# Set to false for self-signed certificates or local development
VERIFY_SSL=true

# =============================================================================
# Safety Controls - Dangerous Operations Protection
# =============================================================================
# These settings control permanently destructive operations that cannot be undone.
# When disabled (false), safe alternatives are used instead:
#   - project_delete → archives the project
#   - label_delete → disabled (use label_update to modify instead)
#   - task_delete → marks task as completed

# Enable permanent project deletion (default: false)
# WARNING: Deletes project AND ALL TASKS inside it. Use project_archive instead.
ENABLE_PROJECT_DELETE=false

# Enable permanent label deletion (default: false)
# WARNING: Removes label from ALL tasks workspace-wide. Use label_update instead.
ENABLE_LABEL_DELETE=false

# Enable permanent task deletion (default: false)
# When disabled, task_delete marks task as completed. Use task_complete for clarity.
ENABLE_TASK_DELETE=false
